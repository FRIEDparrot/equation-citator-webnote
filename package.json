{
  "name": "@friedparrot/equation-citator",
  "version": "1.3.7",
  "description": "Web support for Equation Citator exported citations.",
  "homepage": "https://github.com/FRIEDparrot/equation-citator-webnote#readme",
  "bugs": {
    "url": "https://github.com/FRIEDparrot/equation-citator-webnote/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FRIEDparrot/equation-citator-webnote.git"
  },
  "license": "Apache-2.0",
  "author": "friedparrot",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./markdown-it": {
      "types": "./dist/markdown-it.d.ts",
      "default": "./dist/markdown-it.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "npm run build -- --watch",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build"
  },
  "peerDependencies": {
    "markdown-it": ">=13"
  },
  "peerDependenciesMeta": {
    "markdown-it": {
      "optional": true
    }
  },
  "dependencies": {
    "typescript": "^6.0.3"
  }
}
